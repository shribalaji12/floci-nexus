# ─── AI Provider ──────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# ─── Ollama (local embeddings) ────────────────────────
# Default: http://localhost:11434  (set only if non-standard)
# OLLAMA_URL=http://localhost:11434

# ─── PostgreSQL ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=floci_agents
DB_USER=floci
DB_PASSWORD=floci_secret

# ─── Terraform ────────────────────────────────────────
# Working directory for generated Terraform workspaces
TERRAFORM_BASE_DIR=/tmp/terraform

# ─── Server ───────────────────────────────────────────
PORT=3002

# ─── Approval mode ────────────────────────────────────
# "true"  — auto-approve all plan/apply steps (dev/demo)
# "false" — require manual admin approval via API
AUTO_APPROVE=true
